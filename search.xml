    <entry>
      <title>MarkDown语法</title>
      <link href="/2021/10/10/Style/"/>
      <url>/2021/10/10/Style/</url>
      
        <content type="html"><![CDATA[<hr><p>$\qquad$<font face="微软雅黑"><strong>概括</strong></font>:语句</p><blockquote><p>$$<br>内容<br>$$</p></blockquote><figure class="highlight plaintext"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><span class="line">$\qquad$&lt;font face=&quot;微软雅黑&quot;&gt;**概括**&lt;/font&gt;:语句</span><br><span class="line"></span><br><span class="line">&gt;$$</span><br><span class="line">内容</span><br><span class="line">$$</span><br></pre></td></tr></table></figure><hr><p>题目</p><details><summary><font color="#8076a3"><strong><answer>$\nabla$证</answer><strong></strong></strong></font></summary><blockquote style="border-color:#8076a3;color:#8076a3">$$答案$$$\\\\$</blockquote></details><figure class="highlight plaintext"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br></pre></td><td class="code"><pre><span class="line">题目</span><br><span class="line">&lt;details&gt;</span><br><span class="line">&lt;summary&gt;&lt;font color=#8076a3&gt;&lt;strong&gt;&lt;answer&gt;$\nabla$证&lt;/answer&gt;&lt;strong&gt;&lt;/font&gt;&lt;/summary&gt;</span><br><span class="line"></span><br><span class="line">&lt;blockquote style=&quot;border-color:#8076a3;color:#8076a3&quot;&gt;</span><br><span class="line">$$</span><br><span class="line">答案</span><br><span class="line">$$</span><br><span class="line">&lt;/bockquote&gt;</span><br><span class="line">$\\\\$</span><br><span class="line">&lt;/details&gt;</span><br></pre></td></tr></table></figure><hr><p>$\qquad$<font face="微软雅黑"><strong>对齐</strong></font>:语句</p><blockquote><font size="4">$$\begin{aligned}&左对齐\\\\&左又对齐\\\\&左又又对齐\\\\&左又又又对齐\end{aligned}$$</font></blockquote><figure class="highlight plaintext"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br></pre></td><td class="code"><pre><span class="line">$\qquad$&lt;font face=&quot;微软雅黑&quot;&gt;**对齐**&lt;/font&gt;:语句</span><br><span class="line">&gt;&lt;font size=4&gt;</span><br><span class="line">$$</span><br><span class="line">\begin&#123;aligned&#125;</span><br><span class="line">&amp;左对齐\\\\</span><br><span class="line">&amp;左又对齐\\\\</span><br><span class="line">&amp;左又又对齐\\\\</span><br><span class="line">&amp;左又又又对齐</span><br><span class="line">\end&#123;aligned&#125;</span><br><span class="line">$$</span><br><span class="line">&lt;/font&gt;</span><br></pre></td></tr></table></figure><hr>]]></content>
      
      
